---
// ABOUTME: Lists the most recently dated docs pages for the top page's "新着" section.
// ABOUTME: Sorts by frontmatter `date` descending and shows title, date, and status.
import { getCollection } from 'astro:content';
import { formatPageDate, getStatusEmoji } from './page-metadata.js';

interface Props {
  /** How many entries to show. Defaults to 10. */
  limit?: number;
}

const { limit = 10 } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

/** Pages that are entry points or system pages, not "articles". */
const EXCLUDED_IDS = new Set(['', 'index', '404']);

const toTime = (value: unknown): number => {
  const time = new Date(value as string | Date).getTime();
  return Number.isNaN(time) ? -Infinity : time;
};

const recent = (await getCollection('docs'))
  .filter((entry) => !EXCLUDED_IDS.has(entry.id))
  .sort((a, b) => toTime(b.data.date) - toTime(a.data.date))
  .slice(0, limit);
---

{
  recent.length > 0 && (
    <ul class="recent-updates">
      {recent.map((entry) => (
        <li>
          <a href={`${base}/${entry.id}/`}>
            <span class="recent-title">
              {getStatusEmoji(entry.data.status)} {entry.data.title}
            </span>
            {formatPageDate(entry.data.date) && (
              <time class="recent-date">{formatPageDate(entry.data.date)}</time>
            )}
          </a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .recent-updates {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .recent-updates a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.3rem 0;
    color: var(--sl-color-white);
    text-decoration: none;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .recent-updates li:last-child a {
    border-bottom: none;
  }

  .recent-updates a:hover .recent-title {
    text-decoration: underline;
  }

  .recent-title {
    min-width: 0;
  }

  .recent-date {
    flex-shrink: 0;
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
    color: var(--sl-color-gray-3);
  }
</style>
