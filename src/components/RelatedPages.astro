---
// ABOUTME: Displays a list of related pages that share at least one tag with the current page.
// ABOUTME: Shows at most 3 related entries to keep the section compact and scannable.
import { getCollection } from 'astro:content';

interface Props {
  /** entry.id format: e.g. "history/kojiki-nihon-shoki-history" (no extension, no leading slash) */
  currentSlug: string;
  tags: string[];
}

const { currentSlug, tags } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const related =
  tags.length === 0
    ? []
    : (await getCollection('docs'))
        .filter(
          (entry) =>
            entry.id !== currentSlug &&
            (entry.data.tags ?? []).some((t) => tags.includes(t)),
        )
        .slice(0, 3);
---

{
  related.length > 0 && (
    <aside class="related-pages" aria-label="Related pages">
      <h2>関連ページ</h2>
      <ul>
        {related.map((entry) => (
          <li>
            <a href={`${base}/${entry.id}/`}>
              {entry.data.title}
              {entry.data.status && (
                <span class="related-status">{entry.data.status}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}

<style>
  .related-pages {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--sl-color-gray-5);
  }

  .related-pages h2 {
    font-size: 1rem;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.75rem;
  }

  .related-pages ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .related-pages a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--sl-color-white);
    text-decoration: none;
  }

  .related-pages a:hover {
    text-decoration: underline;
  }

  .related-status {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
  }
</style>
